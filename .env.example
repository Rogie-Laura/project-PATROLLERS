# Public site URL for install QR links (always use production, not preview URLs)
NEXT_PUBLIC_PATROLLERS_URL=https://project-patrollers.vercel.app

# Supabase — copy to .env.local and fill in your project values
# This repo is public: use Vercel env vars for production; never commit real keys.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Server-only key (Settings -> API -> service_role). Required for badge-number
# login and location inserts. NEVER expose this in client code or commit it.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Google Directions API — traffic-aware routing (optional; OSRM fallback if missing)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key_here

# OpenWeatherMap — optional map overlay layers (clouds, precipitation) on command map
# Rain radar overlay works without this key (RainViewer). Get a free key at openweathermap.org
OPENWEATHERMAP_API_KEY=your_openweathermap_api_key_here

# Firebase Cloud Messaging (optional — dispatch + force-location when app is backgrounded)
# Create a Firebase project (FCM only). Service account JSON → these three vars.
FIREBASE_PROJECT_ID=your_firebase_project_id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# PRO4A COMMAND — read-only patrol unit counts (Police Intervention)
# Generate a long random string; set the same value on PRO4A-COMMAND as PATROLLERS_COUNTS_API_KEY
PATROLLERS_COMMAND_API_KEY=your_shared_secret_here
